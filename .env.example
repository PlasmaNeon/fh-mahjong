# Copy to .env and adjust, then: docker compose --profile full up
#
# The RL policy server needs a real model checkpoint (.pt). The repo only ships
# the manifest, which references training-box paths, so point these at a host
# directory that contains your checkpoint file.

# Host directory mounted read-only into the policy container at /checkpoints.
RL_CHECKPOINT_DIR=./ai/checkpoints

# Checkpoint filename inside RL_CHECKPOINT_DIR (served via --checkpoint).
RL_CHECKPOINT_FILE=model.pt
